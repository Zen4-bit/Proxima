{
    "name": "brainstorm",
    "version": "4.0.0",
    "description": "brAInstorm - Local MCP Server (requires localhost network access for AI coding tools)",
    "license": "SEE LICENSE.md",
    "author": "mindflowgo, codexAI",
    "keywords": [
        "mcp",
        "ai",
        "brainstorm",
        "chatgpt",
        "claude",
        "gemini",
        "perplexity",
        "multi-ai",
        "electron"
    ],
    "type": "module",
    "main": "electron/main-v2.cjs",
    "scripts": {
        "start": "electron .",
        "mcp": "node src/mcp-server-v3.js",
        "prepare:runtime": "node scripts/prepare-packaged-runtime.cjs",
        "build": "electron-builder",
        "prebuild": "npm run prepare:runtime",
        "build:win": "electron-builder --win --x64",
        "prebuild:win": "npm run prepare:runtime",
        "build:installer": "electron-builder --win --x64 -c.win.target=nsis",
        "prebuild:installer": "npm run prepare:runtime",
        "build:mac": "electron-builder --mac",
        "prebuild:mac": "npm run prepare:runtime",
        "build:mac:dir": "electron-builder --mac dir",
        "prebuild:mac:dir": "npm run prepare:runtime"
    },
    "build": {
        "asar": true,
        "appId": "com.brainstorm.app",
        "productName": "brAInstorm",
        "copyright": "Copyright © 2026 brAInstorm",
        "directories": {
            "output": "dist"
        },
        "files": [
            "**/*",
            "!dist/**/*",
            "!build/**/*",
            "!sdk/**/*",
            "!MODULES.md"
        ],
        "asarUnpack": [
            "**/*.node",
            "**/*.wasm",
            "**/*.dll",
            "**/*.dylib",
            "**/*.so"
        ],
        "extraResources": [
            {
                "from": "build/packaged-runtime/src",
                "to": "runtime/src"
            },
            {
                "from": "build/packaged-runtime/skills",
                "to": "runtime/skills"
            },
            {
                "from": "build/packaged-runtime/node_modules",
                "to": "runtime/node_modules"
            },
            {
                "from": "build/packaged-runtime/runtime-version.json",
                "to": "runtime/runtime-version.json"
            }
        ],
        "mac": {
            "target": [
                {
                    "target": "dmg",
                    "arch": [
                        "universal"
                    ]
                },
                {
                    "target": "zip",
                    "arch": [
                        "universal"
                    ]
                }
            ],
            "category": "public.app-category.developer-tools",
            "icon": "assets/brainstorm-app-icon.icns",
            "artifactName": "${productName}-${version}-${arch}.${ext}",
            "darkModeSupport": true
        },
        "dmg": {
            "artifactName": "${productName}-${version}-${arch}.${ext}"
        },
        "win": {
            "target": [
                {
                    "target": "nsis",
                    "arch": [
                        "x64"
                    ]
                }
            ],
            "icon": "assets/brainstorm-app-icon.ico",
            "artifactName": "${productName}-Setup-${version}.${ext}"
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true,
            "shortcutName": "brAInstorm"
        }
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.25.3",
        "sql.js": "^1.13.0",
        "zod": "^4.3.6"
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "electron": "^33.4.11",
        "electron-builder": "^25.1.8",
        "http-server": "^14.1.1"
    }
}
